rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Prototype rules: Allow public access for the barber shop demo
    // Since the app uses a custom login system (not Firebase Auth), 
    // we allow public read/write for all collections.
    
    match /barbers/{barberId} {
      allow read, write: if true;
    }

    match /bookings/{bookingId} {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
